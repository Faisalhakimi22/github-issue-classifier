{
  "openapi": "3.1.0",
  "info": {
    "title": "GitHub Issue Triage Bot",
    "version": "1.0.0"
  },
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Healthz",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Healthz Healthz Get"
                }
              }
            }
          }
        }
      }
    },
    "/stats": {
      "get": {
        "summary": "Stats",
        "description": "What has this deploy actually predicted? Token-gated (repo names).",
        "operationId": "stats_stats_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Stats Stats Get"
                }
              }
            }
          }
        }
      }
    },
    "/dashboard": {
      "get": {
        "summary": "Dashboard",
        "description": "Read-only operator view over /stats (data loads with the token,\nclient-side; the page itself carries no repo data).",
        "operationId": "dashboard_dashboard_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "title": "Response Dashboard Dashboard Get"
                }
              }
            }
          }
        }
      }
    },
    "/webhook": {
      "post": {
        "summary": "Webhook",
        "operationId": "webhook_webhook_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Webhook Webhook Post"
                }
              }
            }
          }
        }
      }
    },
    "/api/predict": {
      "post": {
        "summary": "Api Predict",
        "description": "Score an arbitrary issue body without GitHub side effects.\n\nGuarded by the same webhook secret (send it as X-GHIC-Token) so the\nmodel is not an open scoring oracle when deployed publicly.",
        "operationId": "api_predict_api_predict_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Api Predict Api Predict Post"
                }
              }
            }
          }
        }
      }
    }
  }
}