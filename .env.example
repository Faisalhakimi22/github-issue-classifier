# Copy to .env (gitignored). Never commit real values.

# ---------------------------------------------------------------------------
# Data collection / training (ghic.collect)
# ---------------------------------------------------------------------------
# Fine-grained PAT from https://github.com/settings/tokens with public repo
# read access — no write scopes needed. Only used for dataset collection.
GH_TOKEN=ghp_replace_me

# ---------------------------------------------------------------------------
# Webhook service (ghic.service) — all optional in dev, required in prod
# ---------------------------------------------------------------------------
# Secret configured on the GitHub App's webhook settings page.
GHIC_WEBHOOK_SECRET=

# GitHub App credentials (App settings -> General). The private key can be
# passed inline (GHIC_PRIVATE_KEY) or as a file path (GHIC_PRIVATE_KEY_PATH).
GHIC_APP_ID=
GHIC_PRIVATE_KEY_PATH=

# Model + decision threshold. Default prefers models/champion.joblib (the
# calibrated walk-forward-selected model) and falls back to rf_balanced.
GHIC_MODEL_PATH=
GHIC_THRESHOLD=0.5
# Per-repo overrides — run `python -m ghic.backtest` to calibrate these.
# GHIC_REPO_THRESHOLDS=owner/repo=0.35,other/repo=0.6
GHIC_REPO_THRESHOLDS=

# Actions. Everything defaults to the safe side: dry-run on, writes off.
GHIC_DRY_RUN=true
GHIC_POST_COMMENT=false
GHIC_APPLY_LABEL=false
GHIC_LABEL_NAME=predicted:actionable-bug

# Enrichment (author profile + latest release via the GitHub API).
GHIC_ENRICH=true

# Online-evaluation ledger (predictions graded when issues close).
# Unset = data/predictions.jsonl; empty = in-memory only.
# GHIC_LEDGER=data/predictions.jsonl

# Duplicate candidates (requires models/dup_index.joblib from
# `python -m ghic.dupdetect --build-index`). Assistive only.
GHIC_SUGGEST_RELATED=true
GHIC_RELATED_MIN_SIM=0.55

# LLM-drafted "missing information" comments (off by default; degrades to a
# deterministic template without an API key). The classifier's decision is
# never delegated to the LLM.
GHIC_DRAFT_MISSING_INFO=false
# ANTHROPIC_API_KEY=sk-ant-...
# GHIC_LLM_MODEL=claude-opus-4-8

# Dev only: accept unsigned webhooks when no secret is set. NEVER in prod.
GHIC_ALLOW_UNSIGNED=false
